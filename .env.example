# ─────────────────────────────────────────────────────────────────────────────
# TAX ME — Environment Variables
# Copy to .env and edit before running the application.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ────────────────────────────────────────────────────────────────────
# "development" enables Swagger UI (/docs) and DEBUG logging.
# "production" disables docs and enables stricter defaults.
ENV=development

# Port the FastAPI server listens on (ignored in Docker — set via docker-compose)
PORT=5000

# ── Local LLM ─────────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint for the on-device model (LM Studio, Ollama, etc.)
# The application works without this — RAG will return an error instead of a reply.
LLM_URL=http://localhost:8080/v1/chat/completions
LLM_MODEL=local-model

# ── Tax Law Updates ────────────────────────────────────────────────────────────
# How often (in hours) to re-fetch new tax regulation articles via DuckDuckGo.
TAX_UPDATE_INTERVAL_HOURS=24

# ── Security ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Defaults to "*" in development and stricter in production.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Requests per minute per IP before 429 is returned.
RATE_LIMIT_RPM=120

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Docker (docker-compose only) ──────────────────────────────────────────────
# Host port the frontend is published on.
APP_PORT=80
